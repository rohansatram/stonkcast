# Copy this file to backend/.env and fill in your Bedrock API key.
# The .env file is gitignored. Short-term Bedrock keys expire (~12h); regenerate as needed.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=eu-central-1
# Optional override (default eu.amazon.nova-lite-v1:0):
# NOVA_MODEL=eu.amazon.nova-pro-v1:0

# Free key from quiverquant.com for congressional-trades signal:
QUIVER_API_KEY=
